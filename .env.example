# AISStream.io API key (https://aisstream.io). Required for ingestion.
AISSTREAM_API_KEY=your_aisstream_api_key

# Google Maps JavaScript API key. Required for the map view.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Optional: bounding box to subscribe to, as JSON.
# Format: [[[lat1, lon1], [lat2, lon2]], ...]
# Default (when unset) is Tokyo Bay: [[[35.0,139.5],[35.7,140.2]]]
# AIS_BBOX=[[[35.0,139.5],[35.7,140.2]]]
