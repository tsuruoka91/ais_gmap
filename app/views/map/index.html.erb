<% content_for :title, "AIS Ship Map" %>

<div id="ais-app">
  <div id="ais-toolbar">
    <span class="ais-title">AIS Ship Map</span>
    <span id="ais-status">Loading...</span>
  </div>
  <div id="ais-map"></div>
</div>

<style>
  html, body { height: 100%; margin: 0; }
  #ais-app { position: fixed; inset: 0; display: flex; flex-direction: column; }
  #ais-toolbar {
    display: flex; align-items: center; gap: 16px;
    padding: 10px 16px; background: #0b3d61; color: #fff;
    font-family: system-ui, sans-serif;
  }
  #ais-toolbar .ais-title { font-weight: 700; font-size: 16px; }
  #ais-status { font-size: 13px; opacity: 0.85; }
  #ais-map { flex: 1 1 auto; }
  .ais-vessel-arrow { line-height: 0; }
  .ais-vessel-arrow svg { display: block; }
</style>

<% if @google_maps_api_key.blank? %>
  <script>
    document.getElementById("ais-status").textContent =
      "GOOGLE_MAPS_API_KEY が未設定です。.env に設定してください。";
  </script>
<% else %>
  <script>
    window.AIS_CONFIG = {
      center: { lat: <%= @map_center[:lat] %>, lng: <%= @map_center[:lng] %> },
      mapId: "<%= j @google_maps_map_id %>",
      vesselsUrl: "<%= api_vessels_path(format: :json) %>",
      viewportUrl: "<%= api_viewport_path %>",
      refreshMs: 5000
    };

    let aisMap;
    let aisClusterer;
    let AdvancedMarkerElement;
    const aisMarkers = {};
    let aisBoxes = [];
    const aisInfoWindow = () => (window.__aisInfo ||= new google.maps.InfoWindow());

    async function initAisMap() {
      const markerLib = await google.maps.importLibrary("marker");
      AdvancedMarkerElement = markerLib.AdvancedMarkerElement;
      aisMap = new google.maps.Map(document.getElementById("ais-map"), {
        center: window.AIS_CONFIG.center,
        zoom: 10,
        mapTypeId: "roadmap",
        mapId: window.AIS_CONFIG.mapId
      });
      aisClusterer = new markerClusterer.MarkerClusterer({ map: aisMap });
      aisMap.addListener("idle", onMapIdle);
      setInterval(fetchVessels, window.AIS_CONFIG.refreshMs);
      refreshBoundingBoxes();
      setInterval(refreshBoundingBoxes, window.AIS_CONFIG.refreshMs);
    }

    async function refreshBoundingBoxes() {
      try {
        const res = await fetch(window.AIS_CONFIG.viewportUrl, { headers: { "Accept": "application/json" } });
        if (!res.ok) return;
        const data = await res.json();
        renderBoundingBoxes(data.bounding_boxes || []);
      } catch (e) {
        /* ignore bounding box fetch failures */
      }
    }

    function renderBoundingBoxes(boxes) {
      aisBoxes.forEach((rect) => rect.setMap(null));
      aisBoxes = boxes.map((box) => {
        const [sw, ne] = box;
        return new google.maps.Rectangle({
          map: aisMap,
          bounds: { south: sw[0], west: sw[1], north: ne[0], east: ne[1] },
          strokeColor: "#e53935",
          strokeOpacity: 0.9,
          strokeWeight: 2,
          fillOpacity: 0,
          clickable: false,
          zIndex: 1
        });
      });
    }

    function onMapIdle() {
      reportViewport();
      fetchVessels();
    }

    async function reportViewport() {
      const bounds = aisMap && aisMap.getBounds();
      if (!bounds) return;
      const ne = bounds.getNorthEast();
      const sw = bounds.getSouthWest();
      const token = document.querySelector('meta[name="csrf-token"]');
      try {
        await fetch(window.AIS_CONFIG.viewportUrl, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "X-CSRF-Token": token ? token.content : ""
          },
          body: JSON.stringify({
            north: ne.lat(),
            south: sw.lat(),
            east: ne.lng(),
            west: sw.lng()
          })
        });
      } catch (e) {
        /* ignore viewport reporting failures */
      }
    }

    function vesselHeading(vessel) {
      return (vessel.true_heading != null && vessel.true_heading !== 511)
        ? vessel.true_heading
        : (vessel.cog != null ? vessel.cog : 0);
    }

    // Build the DOM content for an AdvancedMarkerElement: an arrow SVG that
    // points along the vessel's heading. The wrapper recenters the icon onto
    // the anchor point (AdvancedMarkerElement anchors at bottom-center).
    function buildVesselContent(vessel) {
      const wrapper = document.createElement("div");
      wrapper.className = "ais-vessel-marker";
      wrapper.style.transform = "translateY(50%)";
      const arrow = document.createElement("div");
      arrow.className = "ais-vessel-arrow";
      arrow.innerHTML =
        '<svg width="22" height="22" viewBox="-12 -12 24 24" xmlns="http://www.w3.org/2000/svg">' +
        '<path d="M0,-10 L6,8 L0,4 L-6,8 Z" fill="#1565c0" fill-opacity="0.9" ' +
        'stroke="#ffffff" stroke-width="1"/></svg>';
      arrow.style.transform = "rotate(" + vesselHeading(vessel) + "deg)";
      wrapper.appendChild(arrow);
      return wrapper;
    }

    function updateVesselContent(marker, vessel) {
      const arrow = marker.content && marker.content.querySelector(".ais-vessel-arrow");
      if (arrow) arrow.style.transform = "rotate(" + vesselHeading(vessel) + "deg)";
    }

    function infoContent(v) {
      const name = v.name && v.name.length ? v.name : "(不明)";
      const sog = v.sog != null ? v.sog + " kn" : "-";
      const cog = v.cog != null ? v.cog + "°" : "-";
      const hdg = (v.true_heading != null && v.true_heading !== 511) ? v.true_heading + "°" : "-";
      return `<div style="font-family:system-ui,sans-serif;font-size:13px;line-height:1.5">
        <strong>${name}</strong><br>
        MMSI: ${v.mmsi}<br>
        速力(SOG): ${sog}<br>
        針路(COG): ${cog}<br>
        船首方位: ${hdg}<br>
        更新: ${v.last_message_at || "-"}
      </div>`;
    }

    function vesselsRequestUrl() {
      const url = new URL(window.AIS_CONFIG.vesselsUrl, window.location.origin);
      const bounds = aisMap && aisMap.getBounds();
      if (bounds) {
        const ne = bounds.getNorthEast();
        const sw = bounds.getSouthWest();
        url.searchParams.set("north", ne.lat());
        url.searchParams.set("south", sw.lat());
        url.searchParams.set("east", ne.lng());
        url.searchParams.set("west", sw.lng());
      }
      return url.toString();
    }

    async function fetchVessels() {
      const statusEl = document.getElementById("ais-status");
      try {
        const res = await fetch(vesselsRequestUrl(), { headers: { "Accept": "application/json" } });
        if (!res.ok) throw new Error("HTTP " + res.status);
        const vessels = await res.json();
        renderVessels(vessels);
        statusEl.textContent = `${vessels.length} 隻表示中 / 最終更新 ${new Date().toLocaleTimeString()}`;
      } catch (e) {
        statusEl.textContent = "データ取得に失敗しました: " + e.message;
      }
    }

    function renderVessels(vessels) {
      const seen = {};
      const toAdd = [];
      const toRemove = [];
      vessels.forEach((v) => {
        if (v.latitude == null || v.longitude == null) return;
        seen[v.mmsi] = true;
        const position = { lat: v.latitude, lng: v.longitude };
        let marker = aisMarkers[v.mmsi];
        if (!marker) {
          marker = new AdvancedMarkerElement({
            position: position,
            content: buildVesselContent(v),
            title: v.name || String(v.mmsi),
            gmpClickable: true
          });
          marker.addListener("gmp-click", () => {
            const iw = aisInfoWindow();
            iw.setContent(infoContent(marker.__vessel));
            iw.open({ map: aisMap, anchor: marker });
          });
          aisMarkers[v.mmsi] = marker;
          toAdd.push(marker);
        } else {
          // Only touch the marker when its position or heading actually changed.
          const prev = marker.__vessel || {};
          if (prev.latitude !== v.latitude || prev.longitude !== v.longitude) {
            marker.position = position;
          }
          if (prev.true_heading !== v.true_heading || prev.cog !== v.cog) {
            updateVesselContent(marker, v);
          }
        }
        marker.__vessel = v;
      });

      Object.keys(aisMarkers).forEach((mmsi) => {
        if (!seen[mmsi]) {
          toRemove.push(aisMarkers[mmsi]);
          delete aisMarkers[mmsi];
        }
      });

      if (toAdd.length) aisClusterer.addMarkers(toAdd, true);
      if (toRemove.length) aisClusterer.removeMarkers(toRemove, true);
      // Recluster once after the batch so moving vessels regroup without a map gesture.
      aisClusterer.render();
    }

    window.initAisMap = initAisMap;
  </script>
  <script src="https://unpkg.com/@googlemaps/markerclusterer/dist/index.min.js"></script>
  <script async
    src="https://maps.googleapis.com/maps/api/js?key=<%= j @google_maps_api_key %>&callback=initAisMap&loading=async">
  </script>
<% end %>
